# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Mapbox ───────────────────────────────────────────────────────────────────
# Get your token from https://account.mapbox.com/access-tokens/
VITE_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# ─── Resend (email) ───────────────────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
# Required for super admin authentication emails
RESEND_API_KEY=re_your-resend-api-key

# ─── Super Admin ──────────────────────────────────────────────────────────────
# The email address that receives the super admin one-time login code
# Must match the email of the super admin record in your database
VITE_SUPER_ADMIN_EMAIL=your-email@example.com

# ─── Contact ──────────────────────────────────────────────────────────────────
# Shown in Privacy Policy, Terms of Service, and support pages
VITE_CONTACT_EMAIL=your-email@example.com

# ─── Resend sender (optional) ─────────────────────────────────────────────────
# Set this in Supabase Edge Function secrets, not here
# RESEND_FROM_EMAIL=Campus Explorer <noreply@your-domain.com>
